@model Spring2026_Project3_Jemorgan3.Models.MovieActorViewModel

@{
    ViewData["Title"] = "Assign Actor";
}

<h1>Assign Actor</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        @* This heading uses the Movie object from our ViewModel *@
        <h4>Adding an Actor to: <strong>@Model.Movie?.Title</strong></h4>

        <form asp-action="AssignActors" method="post">
            @* We need to keep track of which Movie ID we are working with *@
            <input type="hidden" asp-for="Movie.Id" />

            <div class="form-group mb-3">
                <label class="control-label">Select an Actor</label>
                @* This dropdown pulls from the ActorList in our ViewModel *@
                <select asp-for="SelectedActorId" class="form-control" asp-items="Model.ActorList">
                    <option value="">-- Choose Actor --</option>
                </select>
                <span class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Assign to Movie" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>