@model Spring2026_Project3_Jemorgan3.Models.MovieDetailsViewModel

@{
    ViewData["Title"] = "Movie Details - " + Model.Movie.Title;
}

<h1>Movie Details</h1>

<div>
    <div class="row">
        <div class="col-md-4">
            @if (Model.Movie.Poster != null)
            {
                <img src="data:image/png;base64,@Convert.ToBase64String(Model.Movie.Poster)"
                     class="img-fluid rounded shadow"
                     alt="@Model.Movie.Title"
                     style="max-height: 500px; width: auto;" />
            }
            else
            {
                <div class="bg-light text-center py-5 border">No Poster Available</div>
            }
        </div>

        <div class="col-md-8">
            <h4>@Model.Movie.Title</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Genre</dt>
                <dd class="col-sm-9">@Model.Movie.Genre</dd>

                <dt class="col-sm-3">Release Year</dt>
                <dd class="col-sm-9">@Model.Movie.Year</dd>

                <dt class="col-sm-3">IMDb</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Movie.IMDbUrl))
                    {
                        <a href="@Model.Movie.IMDbUrl" target="_blank" class="btn btn-sm btn-outline-primary">View Movie on IMDb</a>
                    }
                </dd>
            </dl>

            <hr />
            <h5>Cast (Actors)</h5>
            @if (Model.Movie.ActorMovies != null && Model.Movie.ActorMovies.Any())
            {
                <ul class="list-group">
                    @foreach (var item in Model.Movie.ActorMovies)
                    {
                        <li class="list-group-item">
                            @item.Actor.Name
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No actors assigned to this movie yet.</p>
            }
        </div>
    </div>

    <hr class="mt-5" />

    <div class="mt-4">
        <h2 class="text-center">AI Movie Reviews & Sentiment</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-warning text-center">
                @Model.ErrorMessage
            </div>
        }
        else if (Model.Reviews != null && Model.Reviews.Any())
        {
            <div class="alert @(Model.AverageSentiment >= 0 ? "alert-success" : "alert-danger") text-center">
                <h3>Overall Movie Sentiment Score: <strong>@Model.AverageSentiment.ToString("F2")</strong></h3>
            </div>

            <table class="table table-bordered table-striped mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>5 AI-Generated Reviews for @Model.Movie.Title</th>
                        <th style="width: 150px;">Vader Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var review in Model.Reviews)
                    {
                        <tr>
                            <td>@review.ReviewText</td>
                            <td>
                                <span class="badge @(review.SentimentScore >= 0 ? "bg-primary" : "bg-warning text-dark")">
                                    @review.SentimentScore.ToString("F2")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-center text-muted">No review data available.</p>
        }
    </div>
</div>

<div class="mt-4 mb-5">
    <a asp-action="Edit" asp-route-id="@Model.Movie.Id" class="btn btn-warning">Edit Movie</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>