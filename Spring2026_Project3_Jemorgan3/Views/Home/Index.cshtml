@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-5">
    <h1 class="display-3 mb-3">🎬 MovieDB 2026</h1>
    <p class="lead mb-5 text-muted">A professional database for cinematic exploration and AI-powered sentiment analysis.</p>
    
    <div class="row g-4 mt-2">
        <div class="col-md-6">
            <div class="card h-100 p-4 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-5 mb-3 text-primary">🎞️</div>
                    <h3 class="card-title">Movie Library</h3>
                    <p class="card-text text-muted">Manage your film collection, view detailed posters, and analyze AI-generated reviews with VaderSharp2.</p>
                    <a asp-controller="Movies" asp-action="Index" class="btn btn-primary btn-lg mt-3 w-100">Explore Movies</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 p-4 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-5 mb-3 text-dark">🎭</div>
                    <h3 class="card-title">Actor Profiles</h3>
                    <p class="card-text text-muted">Discover actors, track their filmographies, and see real-time Twitter sentiment analysis via OpenAI.</p>
                    <a asp-controller="Actors" asp-action="Index" class="btn btn-dark btn-lg mt-3 w-100">Explore Actors</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4 border-top">
        <p class="text-muted small">Powered by Azure OpenAI and VaderSharp2 Sentiment Engine</p>
    </div>
</div>