@model Spring2026_Project3_Jemorgan3.Models.ActorDetailsViewModel

@{
    ViewData["Title"] = "Actor Details - " + Model.Actor.Name;
}

<h1>Actor Details</h1>

<div>
    <div class="row">
        <div class="col-md-4">
            @if (Model.Actor.Photo != null)
            {
                <img src="data:image/png;base64,@Convert.ToBase64String(Model.Actor.Photo)"
                     class="img-fluid rounded shadow"
                     alt="@Model.Actor.Name"
                     style="max-height: 400px; width: auto;" />
            }
            else
            {
                <div class="bg-light text-center py-5 border">No Photo Available</div>
            }
        </div>

        <div class="col-md-8">
            <h4>@Model.Actor.Name</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Gender</dt>
                <dd class="col-sm-9">@Model.Actor.Gender</dd>

                <dt class="col-sm-3">Age</dt>
                <dd class="col-sm-9">@Model.Actor.Age</dd>

                <dt class="col-sm-3">IMDb</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Actor.IMDbUrl))
                    {
                        <a href="@Model.Actor.IMDbUrl" target="_blank" class="btn btn-sm btn-outline-primary">View IMDb Profile</a>
                    }
                    else
                    {
                        <span class="text-muted">No link provided</span>
                    }
                </dd>
            </dl>

            <hr />
            <h5>Filmography (Movies)</h5>
            @if (Model.Actor.ActorMovies != null && Model.Actor.ActorMovies.Any())
            {
                <ul class="list-group">
                    @foreach (var item in Model.Actor.ActorMovies)
                    {
                        <li class="list-group-item">
                            <strong>@item.Movie.Title</strong> (@item.Movie.Year)
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No movies linked to this actor yet.</p>
            }
        </div>
    </div>

    <hr class="mt-5" />

    <div class="mt-4">
        <h2 class="text-center">AI Twitter Sentiment Analysis</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-warning text-center">
                @Model.ErrorMessage
            </div>
        }
        else if (Model.Tweets != null && Model.Tweets.Any())
        {
            <div class="alert @(Model.AverageSentiment >= 0 ? "alert-success" : "alert-danger") text-center">
                <h3>Overall Actor Sentiment Score: <strong>@Model.AverageSentiment.ToString("F2")</strong></h3>
            </div>

            <table class="table table-bordered table-striped mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>10 AI-Generated Tweets about @Model.Actor.Name</th>
                        <th style="width: 150px;">Vader Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tweet in Model.Tweets)
                    {
                        <tr>
                            <td>@tweet.ReviewText</td>
                            <td>
                                <span class="badge @(tweet.SentimentScore >= 0 ? "bg-primary" : "bg-warning text-dark")">
                                    @tweet.SentimentScore.ToString("F2")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-center text-muted">No tweet data available.</p>
        }
    </div>
</div>

<div class="mt-4 mb-5">
    <a asp-action="Edit" asp-route-id="@Model.Actor.Id" class="btn btn-warning">Edit Actor</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>